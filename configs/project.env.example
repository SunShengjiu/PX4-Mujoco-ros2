# Optional local overrides for this workspace.
# Copy to configs/project.env and edit as needed.

PX4_MUJOCO_PYTHON=python3
PX4_MUJOCO_CONDA_ENV=px4-mujoco
# Default scene: delta arm scene. You can temporarily switch with
# `make run-stack-delta` or `make run-stack-uav` without editing this file.
PX4_MUJOCO_MODEL=UAV/scene_uav_delta.xml

# Bootstrap locations
PX4_MUJOCO_PX4_DIR=external/PX4-Autopilot
PX4_MUJOCO_PX4_BRANCH=release/1.15
PX4_MUJOCO_PX4_BUILD_DIR=build/px4_sitl_default
PX4_MUJOCO_PX4_AUTOSTART=22002
PX4_MUJOCO_PX4_SIM_MODEL=mujoco_delta
PX4_MUJOCO_MAVLINK_HOST=0.0.0.0
PX4_MUJOCO_TCP_PORT=4560
PX4_MUJOCO_HOVER_THRUST=0.60
PX4_MUJOCO_PHYSICS_SUBSTEPS_PER_SENSOR=10
PX4_MUJOCO_LOCAL_HOVER=1
PX4_MUJOCO_LOCAL_HOVER_TARGET_Z=2.0
PX4_MUJOCO_LOCAL_HOVER_RAMP_SECONDS=3.0
PX4_MUJOCO_QGC_APP=
PX4_MUJOCO_QGC_UDP_PORT=14550
PX4_MUJOCO_ROS2_SETUP=
PX4_MUJOCO_ROS2_WS=ros2_ws
PX4_MUJOCO_UXRCE_DDS_AGENT=MicroXRCEAgent
# Example if you built the agent from source locally:
# PX4_MUJOCO_UXRCE_DDS_AGENT=/home/<user>/Micro-XRCE-DDS-Agent/build/MicroXRCEAgent
PX4_MUJOCO_UXRCE_DDS_PORT=8888
PX4_MUJOCO_BRIDGE_READY_FILE=/tmp/px4_mujoco_bridge_ready
